<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- 顶部下拉选择 -->
    <Spinner
        android:id="@+id/spinner_options"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_spinner"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="#212121"
        android:textSize="14sp"
        android:dropDownVerticalOffset="4dp"
        android:dropDownWidth="match_parent"
        android:popupBackground="@android:color/white"
        android:popupElevation="4dp" />

    <!-- 消息显示区域 (占据剩余空间) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="10dp"
        android:scrollbars="vertical" />

    <!-- 附件预览条 -->
    <LinearLayout
        android:id="@+id/file_preview_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_spinner"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_file_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_submit"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_file_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textColor="#212121"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="middle" />

        <ImageView
            android:id="@+id/iv_clear_file"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close_small"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            tools:ignore="ContentDescription" />
    </LinearLayout>

    <!-- 底部输入卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="2dp"
        app:cardCornerRadius="12dp"
        app:contentPadding="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="1dp"
        app:strokeColor="#E8E8E8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 消息输入框 -->
            <EditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edit"
                android:hint="@string/msg"
                android:textColor="#212121"
                android:textColorHint="#B0B0B0"
                android:textSize="14sp"
                android:maxLines="3"
                android:inputType="textMultiLine"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="18sp"
                android:autoSizeStepGranularity="1sp" />

            <!-- 底部操作栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/check_dpsk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/colorAccent"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/check_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/r1"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_attach"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:text="@string/pkg"
                    app:cornerRadius="22dp"
                    app:strokeColor="@color/colorAccent"
                    app:strokeWidth="1.5dp" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="68dp"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:text="@string/commit"
                    android:textSize="14sp"
                    app:backgroundTint="@color/colorPrimary"
                    android:textColor="@android:color/white"
                    app:cornerRadius="22dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
